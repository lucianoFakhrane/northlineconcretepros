---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found | Northline Concrete Pros"
  description="The requested page could not be found."
  path="/404/"
  noindex
>
  <Header />
  <main id="main" class="not-found">
    <div class="container not-found-inner">
      <p class="error-code">404</p>
      <h1>We couldn't find that page.</h1>
      <p>The page may have moved or the address may be incorrect.</p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-primary">Return Home</a>
        <a href="/contact/" class="btn btn-accent">Request an Estimate</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .not-found { padding-block: var(--space-3xl); text-align: center; }
  .not-found-inner { display: grid; justify-items: center; gap: var(--space-md); }
  .error-code { color: var(--color-primary); font-size: var(--text-display); font-weight: 800; }
  .not-found h1 { font-size: var(--text-headline); }
  .not-found p { color: var(--color-muted); }
  .not-found-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-sm); }
</style>
