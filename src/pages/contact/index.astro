---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Contact Northline Concrete Pros | Free Estimate"
  description="Request a free concrete estimate in the Quad Cities. Fill out our contact form and get matched with local concrete professionals."
  path="/contact/"
>
  <Header />
  <main id="main">
    <PageHero
      title="Get Your Free Estimate"
      subtitle="Tell us about the project. We review each request and look for available local concrete professionals serving your area."
      crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
    />

    <section class="contact-page">
      <div class="container contact-page-grid">
        <div class="contact-page-info">
          <h2>Reach Us Directly</h2>

          <div class="info-block">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m3 6 9 6 9-6M3 6h18v12H3z" />
            </svg>
            <div>
              <p class="info-title">Email</p>
              <a href="mailto:northlineconcretepros@gmail.com">northlineconcretepros@gmail.com</a>
            </div>
          </div>

          <div class="info-block">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 6v6l4 2" />
            </svg>
            <div>
              <p class="info-title">What Happens Next</p>
              <p>We review your request and, when possible, match it with available local concrete professionals.</p>
            </div>
          </div>

          <div class="info-block">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <div>
              <p class="info-title">Coverage Area</p>
              <p>Davenport, Bettendorf, Moline & Rock Island — nearby areas by request.</p>
            </div>
          </div>

          <p class="info-license">Your request is reviewed and matched with available local concrete professionals.</p>
        </div>

        <ContactForm />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-page {
    padding-block: var(--space-2xl);
  }

  .contact-page-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .contact-page-info h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-lg);
  }

  .info-block {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .info-block svg {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.1em;
  }

  .info-title {
    font-weight: 700;
    margin-bottom: var(--space-3xs);
  }

  .info-block a {
    color: var(--color-ink);
    font-weight: 600;
    text-decoration: none;
  }

  .info-block a:hover {
    text-decoration: underline;
  }

  .info-block p {
    color: var(--color-muted);
  }

  .info-license {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
  }

  @media (min-width: 960px) {
    .contact-page-grid {
      grid-template-columns: 0.85fr 1.15fr;
      align-items: start;
    }
  }
</style>
