---
const points = [
  {
    title: 'One request, multiple local options',
    detail: 'Submit a single request and we match it with available local concrete professionals in your area.',
  },
  {
    title: 'Free, no-obligation estimates',
    detail: 'Estimates from matched professionals cost nothing and come with no pressure to hire.',
  },
  {
    title: 'Built for Quad Cities weather',
    detail: 'We connect you with pros who understand freeze-thaw conditions and proper base prep for this climate.',
  },
  {
    title: 'A simple, no-hassle process',
    detail: 'Tell us about your project once, and skip the back-and-forth of calling around for quotes yourself.',
  },
];

const workImage =
  'https://images.unsplash.com/photo-1546816077-623b4eaab352?auto=format&fit=crop&w=1200&q=80';
---

<section class="why">
  <div class="container why-grid">
    <div class="why-media">
      <img
        src={workImage}
        alt="Detail of a finished concrete surface"
        loading="lazy"
        width="1200"
        height="1400"
      />
    </div>

    <div class="why-content">
      <h2>Why Homeowners Use Northline Concrete Pros</h2>
      <p class="measure why-intro">
        We're a free matching service for the Quad Cities — instead of calling around for quotes
        yourself, tell us about your project once and we connect you with available local
        concrete professionals.
      </p>

      <ul class="why-list">
        {
          points.map((point) => (
            <li>
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              <div>
                <p class="why-list-title">{point.title}</p>
                <p class="why-list-detail measure">{point.detail}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .why {
    padding-block: var(--space-2xl);
    background: var(--color-surface);
  }

  .why-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  .why-media img {
    width: 100%;
    height: 100%;
    max-height: 32rem;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .why-content h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-md);
  }

  .why-intro {
    color: var(--color-muted);
    font-size: var(--text-body);
    margin-bottom: var(--space-lg);
  }

  .why-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why-list li {
    display: flex;
    gap: var(--space-sm);
  }

  .why-list svg {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15em;
  }

  .why-list-title {
    font-weight: 700;
    margin-bottom: var(--space-3xs);
  }

  .why-list-detail {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
  }

  @media (min-width: 900px) {
    .why-grid {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
</style>
