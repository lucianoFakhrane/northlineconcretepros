---
interface Benefit {
  title: string;
  detail: string;
}

interface Step {
  title: string;
  detail: string;
}

interface Props {
  introHeading: string;
  introParagraphs: string[];
  image: string;
  imageAlt: string;
  benefitsHeading: string;
  benefits: Benefit[];
  processHeading: string;
  steps: Step[];
}

const {
  introHeading,
  introParagraphs,
  image,
  imageAlt,
  benefitsHeading,
  benefits,
  processHeading,
  steps,
} = Astro.props;
---

<section class="service-intro">
  <div class="container service-intro-grid">
    <div class="service-intro-media">
      <img src={image} alt={imageAlt} loading="eager" width="1200" height="1400" />
    </div>
    <div class="service-intro-copy">
      <h2>{introHeading}</h2>
      {introParagraphs.map((paragraph) => <p class="measure">{paragraph}</p>)}
    </div>
  </div>
</section>

<section class="service-benefits">
  <div class="container">
    <h2>{benefitsHeading}</h2>
    <ul class="benefits-list">
      {
        benefits.map((benefit) => (
          <li>
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <div>
              <p class="benefit-title">{benefit.title}</p>
              <p class="benefit-detail measure">{benefit.detail}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<section class="service-process">
  <div class="container">
    <h2>{processHeading}</h2>
    <ol class="process-list">
      {
        steps.map((step, index) => (
          <li>
            <span class="process-number">{index + 1}</span>
            <div>
              <p class="process-title">{step.title}</p>
              <p class="process-detail measure">{step.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .service-intro {
    padding-block: var(--space-2xl);
  }

  .service-intro-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  .service-intro-media img {
    width: 100%;
    height: 100%;
    max-height: 28rem;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .service-intro-copy h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-md);
  }

  .service-intro-copy p {
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .service-benefits {
    padding-block: var(--space-2xl);
    background: var(--color-surface);
  }

  .service-benefits h2,
  .service-process h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-lg);
  }

  .benefits-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .benefits-list li {
    display: flex;
    gap: var(--space-sm);
  }

  .benefits-list svg {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15em;
  }

  .benefit-title {
    font-weight: 700;
    margin-bottom: var(--space-3xs);
  }

  .benefit-detail {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
  }

  .service-process {
    padding-block: var(--space-2xl);
  }

  .process-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    counter-reset: step;
  }

  .process-list li {
    display: flex;
    gap: var(--space-md);
  }

  .process-number {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-primary-ink);
    font-weight: 800;
    font-size: var(--text-body-sm);
  }

  .process-title {
    font-weight: 700;
    margin-bottom: var(--space-3xs);
  }

  .process-detail {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
  }

  @media (min-width: 900px) {
    .service-intro-grid {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
</style>
