---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumbs: Crumb[];
}

const { eyebrow, title, subtitle, crumbs } = Astro.props;
---

<section class="page-hero">
  <div class="container page-hero-inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {
          crumbs.map((crumb, index) => (
            <li>
              {crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}
              {index < crumbs.length - 1 && <span class="breadcrumb-sep" aria-hidden="true">/</span>}
            </li>
          ))
        }
      </ol>
    </nav>

    {eyebrow && <p class="page-hero-eyebrow">{eyebrow}</p>}
    <h1 class="page-hero-title">{title}</h1>
    {subtitle && <p class="page-hero-subtitle measure">{subtitle}</p>}

    <div class="page-hero-actions">
      <a href="/contact/" class="btn btn-accent">Request a Free Estimate</a>
    </div>
  </div>
</section>

<style>
  .page-hero {
    background: var(--color-primary);
    color: var(--color-primary-ink);
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .breadcrumbs {
    margin-bottom: var(--space-md);
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--text-label);
    color: color-mix(in oklch, var(--color-primary-ink) 70%, transparent);
  }

  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3xs);
  }

  .breadcrumbs a {
    text-decoration: none;
    color: color-mix(in oklch, var(--color-primary-ink) 85%, transparent);
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumb-sep {
    margin-inline: var(--space-2xs);
    opacity: 0.6;
  }

  .page-hero-eyebrow {
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--color-primary-ink) 80%, transparent);
    margin-bottom: var(--space-2xs);
  }

  .page-hero-title {
    font-size: var(--text-display);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
    max-width: 40rem;
  }

  .page-hero-subtitle {
    font-size: 1.1875rem;
    line-height: var(--leading-snug);
    color: color-mix(in oklch, var(--color-primary-ink) 92%, transparent);
    margin-bottom: var(--space-lg);
  }

  .page-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .page-hero-actions .btn {
    padding-inline: 2rem;
  }
</style>
