---
interface Props {
  introHeading: string;
  introParagraphs: string[];
  image: string;
  imageAlt: string;
  localNotes: string[];
}

const {
  introHeading,
  introParagraphs,
  image,
  imageAlt,
  localNotes,
} = Astro.props;

const services = [
  { title: 'Concrete Driveways', href: '/services/concrete-driveways/' },
  { title: 'Concrete Patios', href: '/services/concrete-patios/' },
  { title: 'Concrete Repair', href: '/services/concrete-repair/' },
  { title: 'Stamped Concrete', href: '/services/stamped-concrete/' },
  { title: 'Sidewalk Installation', href: '/services/sidewalk-installation/' },
];
---

<section class="city-intro">
  <div class="container city-intro-grid">
    <div class="city-intro-media">
      <img src={image} alt={imageAlt} loading="eager" width="1200" height="1400" />
    </div>
    <div class="city-intro-copy">
      <h2>{introHeading}</h2>
      {introParagraphs.map((paragraph) => <p class="measure">{paragraph}</p>)}
      <ul class="local-notes">
        {localNotes.map((note) => (
          <li>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <span>{note}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="city-services">
  <div class="container">
    <h2>Services Available Here</h2>
    <div class="city-services-grid">
      {services.map((service) => (
        <a href={service.href} class="city-service-link">
          {service.title}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .city-intro {
    padding-block: var(--space-2xl);
  }

  .city-intro-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  .city-intro-media img {
    width: 100%;
    height: 100%;
    max-height: 28rem;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .city-intro-copy h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-md);
  }

  .city-intro-copy p {
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .local-notes {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .local-notes li {
    display: flex;
    gap: var(--space-2xs);
    font-size: var(--text-body-sm);
  }

  .local-notes svg {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.2em;
  }

  .city-services {
    padding-block: var(--space-2xl);
    background: var(--color-surface);
  }

  .city-services h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-lg);
  }

  .city-services-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .city-service-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-md);
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 700;
    font-size: var(--text-body-sm);
    transition: border-color var(--duration-fast) var(--ease-out-expo);
  }

  .city-service-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (min-width: 900px) {
    .city-intro-grid {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
</style>
