---
const heroImage =
  '/images/repair.webp';
---

<section class="hero">
  <div class="hero-media">
    <img
      src={heroImage}
      alt="Concrete slab being poured and finished"
      width="1800"
      height="1200"
      fetchpriority="high"
    />
    <div class="hero-scrim" aria-hidden="true"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-badge">Davenport · Bettendorf · Moline · Rock Island</p>
    <h1 class="hero-title">Concrete Help for<br />Quad Cities Homeowners</h1>
    <p class="hero-subtitle measure">
      Driveways, patios, stamped concrete and repair — request a free estimate and get matched
      with local concrete professionals serving Davenport and the Quad Cities.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-accent">Request a Free Estimate</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: min(90vh, 760px);
    color: var(--color-primary-ink);
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    inset: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      oklch(0.19 0.014 240 / 0.55) 0%,
      oklch(0.19 0.014 240 / 0.35) 38%,
      oklch(0.4 0.09 205 / 0.82) 100%
    );
  }

  .hero-content {
    position: relative;
    padding-block: var(--space-2xl) var(--space-xl);
    max-width: 46rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary-ink);
    background: color-mix(in oklch, var(--color-ink) 30%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-primary-ink) 35%, transparent);
    padding: var(--space-3xs) var(--space-sm);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    font-size: var(--text-display);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-size: 1.1875rem;
    line-height: var(--leading-snug);
    color: color-mix(in oklch, var(--color-primary-ink) 92%, transparent);
    margin-bottom: var(--space-lg);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero-actions .btn {
    padding-inline: 2rem;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding-block: var(--space-3xl) var(--space-2xl);
    }
  }
</style>
