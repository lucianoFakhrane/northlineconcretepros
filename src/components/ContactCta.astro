---
import ContactForm from './ContactForm.astro';
---

<section class="contact" id="contact">
  <div class="container contact-grid">
    <div class="contact-copy">
      <h2>Get Your Free Estimate</h2>
      <p class="measure">
        Tell us about the project. We aim to review requests within one business day. No pressure,
        no obligation.
      </p>

      <div class="contact-direct">
        <a href="mailto:northlineconcretepros@gmail.com" class="contact-direct-item">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16v16H4z" opacity="0"></path>
            <path d="m3 6 9 6 9-6M3 6h18v12H3z"></path>
          </svg>
          <span>northlineconcretepros@gmail.com</span>
        </a>
        <p class="contact-hours">Your request is reviewed and matched with available local concrete professionals within one business day.</p>
      </div>
    </div>

    <ContactForm />
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-2xl);
    background: var(--color-surface);
  }

  .contact-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .contact-copy h2 {
    font-size: var(--text-headline);
    margin-bottom: var(--space-sm);
  }

  .contact-copy > p {
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .contact-direct {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-direct-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 700;
  }

  .contact-direct-item svg {
    color: var(--color-primary);
  }

  .contact-hours {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
    margin-top: var(--space-2xs);
  }

  @media (min-width: 960px) {
    .contact-grid {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: start;
    }
  }
</style>
